ออกไปหา Telegram ---\nmsg.payload = {\n    \"chat_id\": \"8776453068\",\n    \"text\": alertMsg\n};\n\nreturn msg;","outputs":1,"timeout":0,"noerr":0,"initialize":"","finalize":"","libs":[],"x":990,"y":520,"wires":[["5cada06ef912f687","bac9387e505cf4d9"]]},{"id":"f6e03d7f311668db","type":"function","z":"db17751bf47342ad","name":"ML \"Heuristic Weighted-Scoring Model for Adaptive Scheduling\"","func":"// --- 1. Data Ingestion ---\nlet score = (msg.payload.score !== undefined) ? msg.payload.score : 0;\nlet lux = msg.payload.light || 0;  \n\n// ป้องกันค่าหลุดกรอบ (Clip values)\nlet cleanScore = Math.max(0, Math.min(score, 100));\nlet cleanLux = Math.max(0, Math.min(lux, 500));\n\n// --- 2. Linear Regression Model ---\nconst intercept = 900;   \nconst w_score = 5.4;     \nconst w_lux = 0.72;      \n\nlet nextTimer = Math.floor(intercept + (w_score * cleanScore) + (w_lux * cleanLux));\n\n// --- 3. Status Labeling & Advisory (Professional Tone) ---\nlet statusLabel, advisory;\n\nif (nextTimer >= 1620) { // >= 27 นาที\n    statusLabel = \"🟢 Optimal (เหมาะสม)\";\n    advisory = \"พฤติกรรมและสภาพแวดล้อมอยู่ในเกณฑ์มาตรฐานที่ปลอดภัยต่อดวงตา\";\n} else if (nextTimer >= 1260) { // >= 21 นาที\n    statusLabel = \"🟡 Acceptable (เฝ้าระวัง)\";\n    advisory = \"ตรวจพบระยะห่างหน้าจอที่ใกล้เกินไปในบางช่วง แนะนำให้ปรับระดับสายตาให้เหมาะสม\";\n} else {\n    statusLabel = \"🔴 Requires Attention (มีความเสี่ยง)\";\n    advisory = \"สภาพแสงไม่เพียงพอ หรือระยะห่างหน้าจอไม่ปลอดภัย ระบบปรับลดเวลาทำงานเพื่อป้องกันภาวะตาล้า (Visual Fatigue)\";\n}\n\n// --- 4. Output Generation (Professional Report Format) ---\nlet report = `📑 Workspace Health & Ergonomics Report\\n`;\nreport += `=================================\\n`;\nreport += `[1] Assessment Summary\\n`;\nreport += `Status: ${statusLabel}\\n\\n`;\n\nreport += `[2] Telemetry Metrics\\n`;\nreport += `- Posture Score : ${cleanScore}/100\\n`;\nreport += `- Ambient Light : ${cleanLux} Lux\\n\\n`;\n\nreport += `[3] System Action\\n`;\nreport += `- Allocated Time: ${Math.floor(nextTimer / 60)} mins ${nextTimer % 60} secs\\n`;\nreport += `- Advisory : ${advisory}\\n`;\nreport += `=================================\\n`;\nreport += `Automated by Smart Desk AI Gateway`;\n\n// --- 5. Prepare Messages ---\nlet out1 = {\n    payload: {\n        \"chat_id\": \"8776453068\", // Chat ID ของคุณ\n        \"text\": report\n    }\n};\n\nlet out2 = {\n    payload: \"SET_TIMER:\" + nextTimer\n};\n\nreturn [out1, out2];","outputs":2,"timeout":0,"noerr":0,"initialize":"","finalize":"","libs":[],"x":1150,"y":600,"wires":[["5cada06ef912f687","bac9387e505cf4d9"],["dcb6c413d673cd47","bac9387e505cf4d9"]]},{"id":"bac9387e505cf4d9","type":"debug","z":"db17751bf47342ad","name":"Event Output Log","active":true,"tosidebar":true,"console":false,"tostatus":false,"complete":"payload","targetType":"msg","statusVal":"","statusType":"auto","x":1570,"y":460,"wires":[]},{"id":"5cada06ef912f687","type":"http request","z":"db17751bf47342ad","name":"Send Telegram","method":"POST","ret":"obj","paytoqs":"ignore","url":"https://api.telegram.org/bot8868384756:AAGeQq_NSXkwUwXIiO1oh8SRPm6SPXBaybs/sendMessage","tls":"","persist":false,"proxy":"","insecureHTTPParser":false,"authType":"","senderr":false,"headers":[{"keyType":"other","keyValue":"Content-Type","valueType":"other","valueValue":"application/json"}],"x":1560,"y":560,"wires":[[]]},{"id":"dcb6c413d673cd47","type":"mqtt out","z":"db17751bf47342ad","name":"","topic":"smartdesk/control","qos":"0","retain":"false","respTopic":"","contentType":"","userProps":"","correl":"","expiry":"","broker":"208f4af71908eab4","x":1570,"y":720,"wires":[]},{"id":"mqtt_in_local_telemetry","type":"mqtt in","z":"db17751bf47342ad","name":"Local: smartdesk/telemetry","topic":"smartdesk/telemetry","qos":"0","datatype":"auto-detect","broker":"208f4af71908eab4","nl":false,"rap":true,"rh":0,"inputs":0,"x":430,"y":1120,"wires":[["json_local_tele"]]},{"id":"json_local_tele","type":"json","z":"db17751bf47342ad","name":"","property"