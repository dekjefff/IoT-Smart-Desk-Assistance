2ad","name":"แยกค่าโชว์ Dashboard Local","func":"// ดึงค่าจาก msg.payload ที่ได้รับจากโหนด JSON Object\nlet score = { payload: msg.payload.score || 0 };\nlet temp  = { payload: msg.payload.temp  || 0 };\n\n// ส่งออก 2 ช่อง: ช่อง 1 ไป Gauge Score, ช่อง 2 ไป Gauge Temp\nreturn [score, temp];","outputs":2,"x":810,"y":160,"wires":[["ui_gauge_score"],["ui_gauge_temp"]]},{"id":"ui_gauge_score","type":"ui_gauge","z":"db17751bf47342ad","name":"Dashboard: Score","group":"70acae3271fee8b6","order":9,"width":0,"height":0,"gtype":"gage","title":"Posture Score","label":"%","format":"{{value}}","min":0,"max":100,"colors":["#ff0000","#e6e600","#00ef27"],"seg1":"","seg2":"","diff":false,"className":"","x":1110,"y":120,"wires":[]},{"id":"ui_gauge_temp","type":"ui_gauge","z":"db17751bf47342ad","name":"Dashboard: Temp","group":"70acae3271fee8b6","order":6,"width":0,"height":0,"gtype":"gage","title":"Temperature","label":"°C","format":"{{value}}","min":0,"max":"45","colors":["#0021ff","#00ef27","#ff0000"],"seg1":"","seg2":"","diff":false,"className":"","x":1110,"y":200,"wires":[]},{"id":"tb_attr_lamp","type":"mqtt in","z":"db17751bf47342ad","name":"TB: Lamp (Attr)","topic":"v1/devices/me/attributes","qos":"2","datatype":"auto-detect","broker":"d3f66166327d0196","nl":false,"rap":false,"inputs":0,"x":400,"y":980,"wires":[["lamp_logic_updated"]]},{"id":"nr_dash_lamp","type":"ui_switch","z":"db17751bf47342ad","name":"Local: Lamp Switch","label":"โคมไฟ (Lamp)","tooltip":"","group":"70acae3271fee8b6","order":4,"width":0,"height":0,"passthru":true,"decouple":"false","topic":"lamp_local","topicType":"str","style":"","onvalue":"1","onvalueType":"num","onicon":"","oncolor":"","offvalue":"0","offvalueType":"num","officon":"","offcolor":"","animate":false,"className":"","x":410,"y":1040,"wires":[["lamp_logic_updated"]]},{"id":"blynk_v4_timer","type":"blynk-iot-in-write","z":"db17751bf47342ad","name":"Blynk: Timer (V4)","pin":"4","pin_all":false,"client":"08857a55bcb11108","x":400,"y":1580,"wires":[["timer_logic_processor"]]},{"id":"tb_attr_timer","type":"mqtt in","z":"db17751bf47342ad","name":"TB: Timer (Attr)","topic":"v1/devices/me/attributes","qos":"2","datatype":"auto-detect","broker":"d3f66166327d0196","nl":false,"rap":false,"inputs":0,"x":390,"y":1640,"wires":[["timer_logic_processor"]]},{"id":"nr_dash_timer","type":"ui_numeric","z":"db17751bf47342ad","name":"Local: Set Timer","label":"เวลาทำงาน (นาที)","tooltip":"","group":"70acae3271fee8b6","order":6,"width":0,"height":0,"wrap":false,"passthru":true,"topic":"timer_local","topicType":"str","format":"{{value}}","min":"1","max":"120","step":1,"className":"","x":390,"y":1680,"wires":[["timer_logic_processor"]]},{"id":"timer_logic_processor","type":"function","z":"db17751bf47342ad","name":"Timer Logic (Min to Sec)","func":"let source = \"Unknown\";\nlet targetMinutes = 0;\n\n// 1. รับค่าจาก Local Dashboard (Topic: timer_local)\nif (msg.topic === \"timer_local\") {\n    source = \"Local_UI\";\n    targetMinutes = parseInt(msg.payload);\n}\n// 2. รับค่าจาก Blynk (V4)\nelse if (msg.pin == 4) {\n    source = \"Blynk\";\n    targetMinutes = parseInt(msg.payload[0]);\n}\n// 3. รับค่าจาก Thingsboard (Attribute: target_timer)\nelse if (msg.payload.target_timer !== undefined) {\n    source = \"Thingsboard\";\n    targetMinutes = parseInt(msg.payload.target_timer);\n} else {\n    return null; // ถ้าไม่ใช่ค่าเวลา ให้ข้ามไป\n}\n\n// แปลงนาทีเป็นวินาที\nlet seconds = targetMinutes * 60;\n\n// แสดงสถานะใต้โหนด\nnode.status({fill: \"green\", shape: \"dot\", text: targetMinutes + \" Min via \" + source});\n\n// ส่งคำสั่งไปยัง ESP32\nreturn { \n    payload: \"SET_TIMER:\" + seconds, \n    source: source \n};","outputs":1,"x":760,"y":1620,"wires":[["mqtt_out_local_control"]]},{"id":"lamp_logic_updated","type":"function","z":"db17751bf47342ad","name":"Lamp Logic & Source ID","func":"let source = \"Unknown\";\nlet lampStatus = 0;\n\n// 1. รับค่าจาก Local Dashboard\nif (msg.topic === \"lamp_local\") {\n    source = \"Local_UI\";\n    lampStatus = msg.payload;\n}\n// 2. รับค่าจาก Blynk (V5)\nelse if (msg.pin == 5) {\n    source = \"Blynk\";\n    lampStatus = msg.payload[0];\n}\n// 3. รับค่าจาก Thingsboard\nelse if (msg.payload.lamp_status !== undefined) {\n    source = \"Thingsboard\";\n    lampStatus = msg.payload.lamp_status ? 1 : 0;\n}\n\nnode.status({fill: (lampStatus == 1 ? \"yellow\" : \"grey\"), shape: \"dot\", text: \"Lamp: \" + (lampStatus == 1 ? \"ON\" : \"OFF\") + \" via \" + source});\n\nreturn { \n    payload: \"CMD:LAMP:\" + lampStatus, \n    source: source \n};","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":770,"y":1000,"wires":[["mqtt_out_local_control"]]},{"id":"dist_logic_updated","type":"function","z":"db17751bf47342ad","name":"Distance Logic & Source ID","func":"let source = \"Unknown\";\nlet distThreshold = 0;\n\n// 1. รับค่าจาก Local Dashboard (Slider)\nif (msg.topic === \"dist_local\") { \n    source = \"Local_UI\";\n    distThreshold = msg.payload;\n} \n// 2. รับค่าจาก Blynk (V6)\nelse if (msg.pin == 6) { \n    source = \"Blynk\";\n    distThreshold = msg.payload;\n}\n// 3. รับค่าจาก Thingsboard (Attribute)\nelse if (msg.payload.distance_threshold !== undefined) {\n    source = \"Thingsboard\";\n    distThreshold = msg.payload.distance_threshold;\n}\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Dist: \" + distThreshold + \" via \" + source });\n\nreturn { \n    payload: \"SET_DIST:\" + distThreshold,\n    source: source\n};","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":740,"y":1320,"wires":[["mqtt_out_local_control"]]},{"id":"blynk_mute_v2","type":"blynk-iot-in-write","z":"db17751bf47342ad","name":"Blynk: Mute (V2)","pin":"2","pin_all":false,"client":"08857a55bcb11108","x":400,"y":1440,"wires":[["mute_logic_updated"]]},{"id":"mute_logic_updated","type":"function","z":"db17751bf47342ad","name":"Mute Logic & Source ID","func":"let source = \"Unknown\";\nlet muteStatus = 0;\n\n// 1. รับค่าจาก Local Dashboard\nif (msg.topic === \"mute_local\") {\n    source = \"Local_UI\";\n    muteStatus = msg.payload;\n}\n// 2. รับค่าจาก Blynk (V2)\nelse if (msg.pin == 2) {\n    source = \"Blynk\";\n    muteStatus = msg.payload[0];\n}\n// 3. รับค่าจาก Thingsboard (Attribute)\nelse if (msg.payload.mute_status !== undefined) {\n    source = \"Thingsboard\";\n    muteStatus = msg.payload.mute_status ? 1 : 0;\n}\n\n// แสดงสถานะที่โหนดเพื่อการ Debug\nnode.status({fill: (muteStatus == 1 ? \"red\" : \"grey\"), shape: \"dot\", text: \"Mute: \" + (muteStatus == 1 ? \"ON\" : \"OFF\") + \" via \" + source});\n\n// ส่งคำสั่งไปยัง ESP32\nreturn { \n    payload: \"CMD:MUTE:\" + muteStatus,\n    source: source\n};","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":650,"y":1440,"wires":[["mqtt_out_local_control"]]},{"id":"dc854ba8688195ba","type":"blynk-iot-in-write","z":"db17751bf47342ad","name":"Blynk: Control Lamp (V5)","pin":"5","pin_all":false,"client":"08857a55bcb11108","x":430,"y":900,"wires":[["lamp_logic_updated"]]},{"id":"3a24e78ad38021d0","type":"blynk-iot-in-write","z":"db17751bf47342ad","name":"Blynk: Distance Setup (V6)","pin":"6","pin_all":false,"client":"08857a55bcb11108","x":430,"y":1360,"wires":[["dist_logic_updated"]]},{"id":"unified_reset_score","type":"function","z":"db17751bf47342ad","name":"Reset Score Logic (Unified)","func":"let source = \"Unknown\";\nlet trigger = 0;\n\nif (msg.topic === \"reset_score_local\") {\n    source = \"Local_UI\";\n    trigger = msg.payload;\n}\nelse if (msg.pin == 0) {\n    source = \"Blynk\";\n    trigger = msg.payload[0];\n}\nelse if (msg.payload && msg.payload.reset_score !== undefined) {\n    source = \"Thingsboard\";\n    trigger = msg.payload.reset_score ? 1 : 0;\n}\n\nif (trigger == 1) {\n    node.status({fill: \"yellow\", shape: \"dot\", text: \"Reset Score via \" + source});\n    return { payload: \"CMD:RESET_SCORE\", source: source };\n}\nreturn null;","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":820,"y":1880,"wires":[["mqtt_out_local_from_netpie"]]},{"id":"unified_reset_timer","type":"function","z":"db17751bf47342ad","name":"Reset Timer Logic (Unified)","func":"let source = \"Unknown\";\nlet trigger = 0;\n\nif (msg.topic === \"reset_time_local\") {\n    source = \"Local_UI\";\n    trigger = msg.payload;\n}\nelse if (msg.pin == 1) {\n    source = \"Blynk\";\n    trigger = msg.payload[0];\n}\nelse if (msg.payload && msg.payload.reset_timer !== undefined) {\n    source = \"Thingsboard\";\n    trigger = msg.payload.reset_timer ? 1 : 0;\n}\n\nif (trigger == 1) {\n    node.status({fill: \"green\", shape: \"dot\", text: \"Reset Timer via \" + source});\n    return { payload: \"CMD:RESET_TIMER\", source: source };\n}\nreturn null;","outputs":1,"timeout":"","noerr":0,"initialize":"","finalize":"","libs":[],"x":820,"y":2220,"wires":[["mqtt_out_local_from_netpie"]]},{"id":"tb_attr_in","type":"mqtt in","z":"db17751bf47342ad","name":"TB: Receive Attributes","topic":"v1/devices/me/attributes","qos":"0","datatype":"auto","broker":"d3f66166327d0196","nl":false,"rap":true,"rh":0,"inputs":0,"x":440,"y":2060,"wires":[["tb_json_parser"]]},{"id":"tb_json_parser","type":"json","z":"db17751bf47342ad","name":"json","property":"payload","action":"obj","pretty":false,"x":670,"y":2060,"wires":[["unified_reset_score","unified_reset_timer"]]},{"id":"6a52c61e2321242e","type":"ui_spacer","z":"db17751bf47342ad","name":"spacer","group":"cc275d0874e46fd0","order":1,"width":"6","height":"1"},{"id":"171661971209f639","type":"ui_spacer","z":"db17751bf47342ad","name":"spacer","group":"cc275d0874e46fd0","order":3,"width":10,"height":1},{"id":"56e3c877e77607b2","type":"ui_spacer","z":"db17751bf47342ad","name":"spacer","group":"cc275d0874e46fd0","order":4,"width":6,"height":1},{"id":"903f01d8e30d9ac1","type":"ui_spacer","z":"db17751bf47342ad","name":"spacer","group":"cc275d0874e46fd0","order":5,"width":10,"height":1},{"id":"462fcbf757ff7c2d","type":"ui_spacer